# ── 3. CORE FUNCTIONS ─────────────────────────────────────────────────────────
def sigmoid(x):
    x = np.clip(x, -500, 500)
    return np.where(x>=0, 1/(1+np.exp(-x)), np.exp(x)/(1+np.exp(x)))
def softplus(x): return np.log1p(np.exp(-np.abs(x)))+np.maximum(x,0)
def relu(x):     return np.maximum(0,x)
def rms_norm(x, eps=1e-6): return x/(np.sqrt((x**2).mean(-1,keepdims=True)+eps))
def softmax_ax0(x):
    e = np.exp(x - x.max(0,keepdims=True)); return e/e.sum(0,keepdims=True)

def zinb_nll(y, pi, mu, r):
    eps=1e-8
    pi=np.clip(pi,eps,1-eps); mu=np.clip(mu,eps,1e6); r=np.clip(r,eps,1e4)
    log_nb0 = r*(np.log(r)-np.log(r+mu))
    log_nbk = (sp.gammaln(y+r)-sp.gammaln(r)-sp.gammaln(y+1)
               +r*(np.log(r)-np.log(r+mu))+y*(np.log(mu)-np.log(r+mu)))
    lp = np.where(y==0, np.log(pi+(1-pi)*np.exp(log_nb0)+eps),
                  np.log(1-pi+eps)+log_nbk)
    return -np.mean(lp)

# ── 4. MODEL (vectorised, fast forward pass) ──────────────────────────────────
print("\n[3/7] Building STZINB-GNN...")

class STZINB_GNN:
    def __init__(self, N, in_dim=8, gcn_dim=16, hid=16, n_gcn=3):
        s = 0.1
        self.gcn_W = [np.random.randn(in_dim if i==0 else gcn_dim, gcn_dim)*s
                      for i in range(n_gcn)]
        self.gcn_b = [np.zeros(gcn_dim) for _ in range(n_gcn)]
        # AttnRes pseudo-queries: one d-dim vector per GCN layer.
        # Initialised to zero so that initial softmax weights are uniform
        # (all layers weighted equally at start of training).
        # NOTE: in this NumPy prototype these vectors are NOT updated
        # during training — only the ZINB output-head weights are trained.
        # In a full PyTorch implementation all parameters would be updated
        # jointly via backpropagation through the ZINB NLL loss.
        self.ar_q = np.zeros((n_gcn, gcn_dim), dtype=np.float32)
        # GRU
        id_ = gcn_dim+hid
        self.Wr=np.random.randn(id_,hid)*s; self.br=np.zeros(hid)
        self.Wz=np.random.randn(id_,hid)*s; self.bz=np.zeros(hid)
        self.Wn=np.random.randn(id_,hid)*s; self.bn=np.zeros(hid)
        # Temporal attention
        self.Wq=np.random.randn(hid,hid)*s; self.Wk=np.random.randn(hid,hid)*s
        self.Wv=np.random.randn(hid,hid)*s; self.Wo=np.random.randn(hid,hid)*s
        # Fusion
        self.Wf=np.random.randn(hid*2,hid)*s; self.bf=np.zeros(hid)
        # ZINB
        self.Wpi=np.random.randn(hid,1)*s; self.bpi=np.zeros(1)
        self.Wmu=np.random.randn(hid,1)*s; self.bmu=np.zeros(1)
        self.Wr2=np.random.randn(hid,1)*s; self.br2=np.full(1,0.5)
        self.N=N; self.gcn_dim=gcn_dim; self.hid=hid; self.n_gcn=n_gcn

    def node_feats(self, C, t):
        N=self.N; F=np.zeros((N,8),dtype=np.float32)
        F[:,0]=C[:,t]; F[:,1]=C[:,t-1] if t>0 else 0
        F[:,2]=C[:,t-2] if t>1 else 0; F[:,3]=C[:,t-3] if t>2 else 0
        w=C[:,max(0,t-4):t+1]; F[:,4]=w.mean(1); F[:,5]=w.std(1)
        F[:,6]=(C[:,t]==0).astype(float); F[:,7]=np.log1p(C[:,t])
        return F

    def gcn_attnres(self, X, A):
        """
        Forward pass through GCN layers followed by depth-wise AttnRes aggregation.
        Each GCN layer output is stored; a learned pseudo-query ar_q[l] computes
        dot-product attention scores against RMSNorm-ed layer outputs, and the
        final representation is a softmax-weighted sum of all layer outputs.
        Because ar_q is fixed at zero in this prototype, the softmax weights
        are uniform (1/L each) — equivalent to simple mean pooling over layers.
        In a full backprop implementation ar_q would be learned and weights
        would become input-dependent and non-uniform.
        """
        blocks=[]; H=X
        for i,(W,b) in enumerate(zip(self.gcn_W,self.gcn_b)):
            H=relu(A@H@W+b); blocks.append(H)
        # Compute depth-wise softmax attention weights.
        # Logits = ar_q[l] · RMSNorm(mean of layer output over nodes).
        # With ar_q fixed at zero all logits are 0, so softmax gives
        # uniform weights (1/L). Weighted sum then equals the layer mean.
        V=np.stack(blocks,0)                        # [L, N, d]
        K=rms_norm(V.mean(1))                       # [L, d]
        logits=np.einsum('ld,ld->l', self.ar_q, K) # [L]
        alpha=np.exp(logits-logits.max())
        alpha/=alpha.sum()
        return np.einsum('l,lnd->nd', alpha, V), alpha

    def gru_step(self, x, h):
        c=np.concatenate([x,h],-1)
        r=sigmoid(c@self.Wr+self.br); z=sigmoid(c@self.Wz+self.bz)
        n=np.tanh(np.concatenate([x,r*h],-1)@self.Wn+self.bn)
        return (1-z)*h+z*n

    def temp_attn(self, H_seq):
        """
        Single-query scaled dot-product attention over the temporal sequence.
        Query Q  : projection of the LAST GRU hidden state h_{T} via Wq. [N, d]
        Keys  K  : projection of ALL hidden states h_{1..T} via Wk.      [T, N, d]
        Values V_: projection of ALL hidden states h_{1..T} via Wv.      [T, N, d]
        Scores   : Q · K^T / sqrt(d), giving one scalar per (time, node). [T, N]
        Weights  : softmax over the time dimension for each node.          [T, N]
        Output   : weighted sum of V_ over time, projected by Wo.         [N, d]
        Note: this is NOT multi-head attention; there is a single query
        per node derived from the most recent hidden state only.
        """
        T,N,d=H_seq.shape
        Q=H_seq[-1]@self.Wq                         # [N,d]
        K=(H_seq.reshape(T*N,d)@self.Wk).reshape(T,N,d)
        V_=(H_seq.reshape(T*N,d)@self.Wv).reshape(T,N,d)
        scores=np.einsum('nd,tnd->tn',Q,K)/np.sqrt(d)  # [T,N]
        w=softmax_ax0(scores)
        ctx=np.einsum('tn,tnd->nd',w,V_)@self.Wo
        return ctx, w

    def forward(self, C, A, seq_len=8):
        """
        Full forward pass over the last seq_len time steps of count matrix C.
        Steps:
          1. For each time step in [T-seq_len, T): build node features,
             run GCN + AttnRes spatial encoding, update GRU hidden state.
          2. Stack all GRU hidden states into H_stack [seq_len, N, hid].
          3. Run single-query temporal attention over H_stack.
          4. Concatenate last GRU state and attention context, pass through
             one ReLU fusion layer.
          5. Project fused representation to ZINB parameters (pi, mu, r)
             via three independent linear heads with sigmoid/softplus.
        Returns pi, mu, r (each [N]), plus H_stack, temporal attention
        weights, and AttnRes alpha vectors for analysis.
        """
        T=C.shape[1]; h=np.zeros((self.N,self.hid),dtype=np.float32)
        H_seq=[]; ar_alphas=[]
        for t in range(max(0,T-seq_len),T):
            X=self.node_feats(C,t)
            Hs,al=self.gcn_attnres(X,A); ar_alphas.append(al)
            h=self.gru_step(Hs,h); H_seq.append(h.copy())
        H_stack=np.stack(H_seq,0)
        ctx,tw=self.temp_attn(H_stack)
        fused=relu(np.concatenate([h,ctx],-1)@self.Wf+self.bf)
        pi =sigmoid(fused@self.Wpi+self.bpi).squeeze(-1)
        mu =softplus(fused@self.Wmu+self.bmu).squeeze(-1)+1e-6
        r  =softplus(fused@self.Wr2+self.br2).squeeze(-1)+1e-4
        return pi,mu,r,H_stack,tw,ar_alphas

    def predict(self, pi, mu):
        """ZINB marginal mean: E[Y] = (1 - pi) * mu."""
        return (1 - pi) * mu

# ── 4. TRAINING ──────────────────────────────────────────────────────────────
# Two-stage procedure:
#   Stage A — A GradientBoostingRegressor (sklearn) is trained on hand-crafted
#             spatial features as a standalone baseline model (used in Fig 6
#             as 'GCN w/o ZINB'). It is NOT used to initialise or guide the
#             STZINB-GNN weights.
#   Stage B — The STZINB-GNN ZINB output-head weights (Wpi, bpi, Wmu, bmu,
#             Wr2, br2) are updated via stochastic central finite-difference
#             gradient estimation over the ZINB NLL loss. All other weights
#             (GCN, GRU, temporal attention, fusion layer, AttnRes queries)
#             are kept at their random initialisation in this prototype.
#             A production implementation would use PyTorch autograd to train
#             all parameters jointly.
print("\n[4/7] Training STZINB-GNN...")

model = STZINB_GNN(n_states)
T = n_weeks
train_end = int(T*0.70); val_end = int(T*0.85)
SEQ_LEN=8; LR=0.02; N_EPOCHS=80

# Build a feature matrix for a list of time steps.
# For each time step t, constructs an [n_states, 8] hand-crafted feature array
# (current count, 3 lags, 4-week rolling mean and std, zero flag, log1p count),
# then appends the output of one GCN propagation step (A_norm @ X @ W[0] + b[0])
# to give spatial context. Rows from all time steps are stacked vertically.
# Used to train the GBM baseline (Stage A) and to generate GBM test predictions.
def build_feature_matrix(C, t_range, A):
    """Build [n_times * n_states, feature_dim] for all t in t_range."""
    rows=[]
    for t in t_range:
        if t < SEQ_LEN: continue
        X = np.zeros((C.shape[0], 8), dtype=np.float32)
        X[:,0]=C[:,t]; X[:,1]=C[:,t-1]; X[:,2]=C[:,t-2]; X[:,3]=C[:,t-3]
        w=C[:,max(0,t-4):t+1]; X[:,4]=w.mean(1); X[:,5]=w.std(1)
        X[:,6]=(C[:,t]==0).astype(float); X[:,7]=np.log1p(C[:,t])
        # One graph conv step (fast)
        Hg=relu(A@X@model.gcn_W[0]+model.gcn_b[0])
        rows.append(np.column_stack([X, Hg]))
    return np.vstack(rows) if rows else np.zeros((0, 8+model.gcn_dim))

# Stage A: Train a GradientBoostingRegressor on hand-crafted node features
# (current count, lags, rolling mean/std, zero flag, log count) concatenated
# with one GCN-propagated feature vector. Target is log1p(count).
# This model serves as the 'GCN w/o ZINB' baseline in the evaluation table.
# It predicts a point estimate of mu; it has no zero-inflation mechanism.
t_train = range(SEQ_LEN, train_end)
feat_train = build_feature_matrix(counts, t_train, adj_norm)
y_train_flat = np.concatenate([counts[:,t] for t in t_train if t>=SEQ_LEN])
if len(feat_train) > 0:
    scaler = StandardScaler().fit(feat_train)
    feat_s = scaler.transform(feat_train)
    gbm = GradientBoostingRegressor(n_estimators=60, max_depth=3,
                                    learning_rate=0.1, random_state=42)
    gbm.fit(feat_s, np.log1p(y_train_flat))

# Stage B: Update ZINB output-head weights using stochastic
# central finite-difference gradient estimates over mini-batches.
train_losses=[]; val_losses=[]

# For each mini-batch time step, estimate the gradient of the ZINB NLL
# with respect to each ZINB head parameter using central finite differences:
#   grad[i] ≈ (L(w+eps*e_i) - L(w-eps*e_i)) / (2*eps)
# To keep runtime manageable, only a random subset of 5 parameter entries
# per weight matrix are updated per step (coordinate-wise subsampling).
# This is a numerical approximation, NOT analytical/exact gradient descent.
# It is used here because NumPy has no autograd; PyTorch would compute
# exact gradients via backpropagation at a fraction of the cost.
for epoch in range(N_EPOCHS):
    t_batch = np.random.choice(range(SEQ_LEN+1, train_end), size=3, replace=False)
    epoch_loss=0.0
    for tb in t_batch:
        pi,mu,r,_,_,_ = model.forward(counts[:,:tb+1], adj_norm, seq_len=SEQ_LEN)
        y = counts[:,tb].astype(np.float32)
        loss = zinb_nll(y, pi, mu, r)
        epoch_loss += loss
        # Central finite-difference gradient estimate for ZINB head weights.
        # For each sampled parameter index i:
        #   1. Perturb w[i] by +eps, run full forward pass, record loss L+
        #   2. Perturb w[i] by -eps, run full forward pass, record loss L-
        #   3. Estimate grad[i] = (L+ - L-) / (2*eps)
        # Update: w[i] -= lr * clip(grad[i], -0.5, 0.5)
        # Only min(5, param_size) indices are sampled per weight matrix
        # per step to limit the number of forward passes.
        eps=1e-3
        for attr in ['Wpi','bpi','Wmu','bmu','Wr2','br2']:
            W = getattr(model, attr)
            g = np.zeros_like(W)
            flat = W.ravel()
            # Sample a few elements to update (stochastic)
            n_sample = min(5, flat.size)
            idx_sample = np.random.choice(flat.size, n_sample, replace=False)
            for ii in idx_sample:
                orig=flat[ii]
                flat[ii]=orig+eps
                pi2,mu2,r2,_,_,_=model.forward(counts[:,:tb+1],adj_norm,SEQ_LEN)
                lp=zinb_nll(y,pi2,mu2,r2)
                flat[ii]=orig-eps
                pi2,mu2,r2,_,_,_=model.forward(counts[:,:tb+1],adj_norm,SEQ_LEN)
                lm=zinb_nll(y,pi2,mu2,r2)
                flat[ii]=orig
                g.ravel()[ii]=(lp-lm)/(2*eps)
            setattr(model, attr, W - LR*np.clip(g,-0.5,0.5))
    epoch_loss/=len(t_batch)
    # Validation: compute ZINB NLL on the last time step of the val window.
    pi_v,mu_v,r_v,_,_,_=model.forward(counts[:,:val_end],adj_norm,SEQ_LEN)
    val_loss=zinb_nll(counts[:,val_end-1].astype(np.float32),pi_v,mu_v,r_v)
    train_losses.append(float(epoch_loss))
    val_losses.append(float(val_loss))
    if epoch%20==0: print(f"  Epoch {epoch:3d} | Train NLL:{epoch_loss:.4f} | Val NLL:{val_loss:.4f}")

print(f"  Training complete.")

