def smap(ax,vals,title,cmap='YlOrRd',label='',draw_edges=True):
    ax.set_facecolor('#E8F4F8'); ax.grid(True,alpha=0.2)
    vmin=vals.min(); vmax=max(vals.max(),vmin+1e-6)
    norm=Normalize(vmin,vmax)
    if draw_edges:
        for i in range(n_states):
            for j in range(i+1,n_states):
                if adj[i,j]>0:
                    xi,yi=STATE_COORDS[states[i]][1],STATE_COORDS[states[i]][0]
                    xj,yj=STATE_COORDS[states[j]][1],STATE_COORDS[states[j]][0]
                    ax.plot([xi,xj],[yi,yj],'gray',alpha=0.12,lw=0.7)
    for i,s in enumerate(states):
        lo,la=STATE_COORDS[s][1],STATE_COORDS[s][0]
        sz=60+160*(vals[i]-vmin)/(vmax-vmin+1e-8)
        ax.scatter(lo,la,c=[vals[i]],cmap=cmap,norm=norm,s=sz,
                   zorder=5,edgecolors='white',lw=0.5)
    sm=plt.cm.ScalarMappable(cmap=cmap,norm=norm); sm.set_array([])
    plt.colorbar(sm,ax=ax,label=label,shrink=0.7)
    ax.set_xlim(-128,-65); ax.set_ylim(23,50)
    ax.set_title(title); ax.set_xlabel('Longitude'); ax.set_ylabel('Latitude')
    for i in np.argsort(vals)[-6:]:
