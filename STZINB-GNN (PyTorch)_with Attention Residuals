# 5. TRAINING
# ══════════════════════════════════════════════════════════════════════════════
print("\n[4/8] Training STZINB-GNN (full backpropagation)...")

# Chronological train / val / test split (no data leakage)
T         = n_weeks
train_end = int(T * 0.70)   # weeks 1   → 179  (train)
val_end   = int(T * 0.85)   # weeks 180 → 217  (validation)
# weeks 218 → 256 = test

model     = STZINB_GNN(n_states).to(DEVICE)
optimizer = Adam(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)
scheduler = ReduceLROnPlateau(optimizer, mode='min', factor=0.5,
                               patience=15, verbose=False)

# Count trainable parameters
n_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
print(f"  Trainable parameters: {n_params:,}")
print(f"  Train weeks: {train_end} | Val weeks: {val_end-train_end}"
      f" | Test weeks: {T-val_end}")

train_losses = []
val_losses   = []
best_val     = np.inf
best_state   = None
patience_ctr = 0

for epoch in range(N_EPOCHS):
    model.train()

    # Mini-batch: sample BATCH_T time steps from training window
    valid_ts = list(range(SEQ_LEN + 1, train_end))
    t_batch  = np.random.choice(valid_ts,
                                 size=min(BATCH_T, len(valid_ts)),
                                 replace=False)
    epoch_loss = 0.0

    for tb in t_batch:
        optimizer.zero_grad()

        # Forward pass using counts up to time step tb
        pi, mu, r, _, _, _ = model(counts[:, :tb+1], adj_norm,
                                    seq_len=SEQ_LEN)

        # True counts at time tb as the prediction target
        y_tb = torch.tensor(counts[:, tb], dtype=torch.float32,
                             device=DEVICE)

        loss = zinb_nll_loss(y_tb, pi, mu, r)

        # Backpropagation: computes gradients for ALL parameters including
        # AttnRes pseudo-queries ar_q, GCN weights, GRU weights,
        # temporal attention weights, fusion layer, and ZINB head.
        loss.backward()

        # Gradient clipping to prevent exploding gradients
        nn.utils.clip_grad_norm_(model.parameters(), GRAD_CLIP)

        optimizer.step()
        epoch_loss += loss.item()

    epoch_loss /= len(t_batch)

    # Validation loss on the last time step of the validation window
    model.eval()
    with torch.no_grad():
        pi_v, mu_v, r_v, _, _, _ = model(counts[:, :val_end],
                                          adj_norm, seq_len=SEQ_LEN)
        y_val = torch.tensor(counts[:, val_end-1],
                              dtype=torch.float32, device=DEVICE)
        val_loss = zinb_nll_loss(y_val, pi_v, mu_v, r_v).item()

    scheduler.step(val_loss)
    train_losses.append(epoch_loss)
    val_losses.append(val_loss)

    # Save best model state
    if val_loss < best_val:
        best_val   = val_loss
        best_state = {k: v.clone() for k, v in model.state_dict().items()}
        patience_ctr = 0
    else:
        patience_ctr += 1

    if epoch % 20 == 0:
        # Show current AttnRes weights to confirm they are diverging from 1/3
        ar_w = torch.softmax(model.gcn.ar_q.mean(dim=1), dim=0)
        print(f"  Epoch {epoch:3d} | Train NLL: {epoch_loss:.4f}"
              f" | Val NLL: {val_loss:.4f}"
              f" | AttnRes α: [{', '.join(f'{a:.3f}' for a in ar_w.tolist())}]")

    if patience_ctr >= PATIENCE:
        print(f"  Early stopping at epoch {epoch}.")
        break

# Restore best model weights
model.load_state_dict(best_state)
print(f"\n  Training complete. Best Val NLL: {best_val:.4f}")

# Report learned AttnRes weights
with torch.no_grad():
    final_ar = torch.softmax(model.gcn.ar_q.mean(dim=1), dim=0).cpu().numpy()
