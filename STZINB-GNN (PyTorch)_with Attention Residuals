# 4. ZINB LOSS FUNCTION
# ══════════════════════════════════════════════════════════════════════════════

def zinb_nll_loss(y: torch.Tensor,
                  pi: torch.Tensor,
                  mu: torch.Tensor,
                  r:  torch.Tensor) -> torch.Tensor:
    """
    Numerically stable ZINB negative log-likelihood.

    For observed count y_i, zero-inflation pi_i, NB mean mu_i, dispersion r_i:

      Zero case  (y=0):
        log P(Y=0) = log[ pi + (1-pi) * (r/(r+mu))^r ]

      Count case (y=k>0):
        log P(Y=k) = log(1-pi)
                   + lgamma(k+r) - lgamma(r) - lgamma(k+1)
                   + r*log(r/(r+mu))
                   + k*log(mu/(r+mu))

    Uses torch.lgamma for numerically stable evaluation of log-gamma.
    Clamps pi, mu, r to safe ranges before log operations.
    """
    eps = 1e-8
    pi  = torch.clamp(pi,  eps, 1.0 - eps)
    mu  = torch.clamp(mu,  eps, 1e6)
    r   = torch.clamp(r,   eps, 1e4)

    # NB log-probability at zero
    log_nb_zero = r * (torch.log(r) - torch.log(r + mu))

    # NB log-probability at count k (lgamma for numerical stability)
    log_nb_k = (torch.lgamma(y + r)
                - torch.lgamma(r)
                - torch.lgamma(y + 1)
                + r * (torch.log(r) - torch.log(r + mu))
                + y * (torch.log(mu) - torch.log(r + mu)))

    # Zero-inflated mixture
    zero_mask  = (y == 0)
    log_p_zero = torch.log(
        pi + (1.0 - pi) * torch.exp(log_nb_zero) + eps
    )
    log_p_pos  = torch.log(1.0 - pi + eps) + log_nb_k

    log_prob = torch.where(zero_mask, log_p_zero, log_p_pos)
    return -log_prob.mean()


