# GBM baseline — trained on hand-crafted features (no ZINB, no ZI)
def make_feats(C, t_list):
    rows = []
    for t in t_list:
        if t < 4: continue
        X = np.column_stack([
            C[:,t], C[:,t-1], C[:,t-2], C[:,t-3],
            C[:,max(0,t-4):t+1].mean(1),
            C[:,max(0,t-4):t+1].std(1),
            (C[:,t]==0).astype(float),
            np.log1p(C[:,t])
        ])
        rows.append(X)
    return np.vstack(rows) if rows else np.zeros((0,8))

X_tr = make_feats(counts, range(4, train_end))
y_tr = np.concatenate([counts[:,t] for t in range(4, train_end)])
scaler = StandardScaler().fit(X_tr)
gbm = GradientBoostingRegressor(n_estimators=80, max_depth=3,
                                 learning_rate=0.1, random_state=42)
gbm.fit(scaler.transform(X_tr), np.log1p(y_tr))
X_te = make_feats(counts, [n_weeks-1])
y_gbm = np.expm1(gbm.predict(scaler.transform(X_te))) if len(X_te) else y_mean

def eval_metrics(yt, yp, name):
    mae  = mean_absolute_error(yt, yp)
    rmse = np.sqrt(mean_squared_error(yt, yp))
    zm   = yt == 0
    zh   = (yp[zm] < 0.5).mean() * 100 if zm.sum() > 0 else 0.0
    fa   = (yp[zm] >= 0.5).mean() * 100 if zm.sum() > 0 else 0.0
    corr = np.corrcoef(yt, yp)[0,1] if yt.std() > 0 and yp.std() > 0 else 0.0
    return {'Model':name, 'MAE':mae, 'RMSE':rmse,
            'Zero-Hit%':zh, 'FalseAlarm%':fa, 'Corr':corr}

results = [
    eval_metrics(y_true, y_pred_zinb, 'STZINB-GNN (Ours)'),
    eval_metrics(y_true, y_nb,        'GCN + NB (no ZI)'),
    eval_metrics(y_true, y_gbm,       'GBM baseline'),
    eval_metrics(y_true, y_arima,     'ARIMA'),
    eval_metrics(y_true, y_mean,      'Mean Baseline'),
    eval_metrics(y_true, y_naive,     'Naive (Last Obs)'),
]
