X_b_np[:, 7] = np.log1p(counts[:, t_last])

X_b_t = torch.tensor(X_b_np, device=DEVICE)
model.eval()
with torch.no_grad():
    H_base, _ = model.gcn(X_b_t, adj_norm)
    sens = []
    for fi in range(8):
        X_p = X_b_t.clone()
        X_p[:, fi] = X_p[:, fi] + 0.1 * (X_b_t[:, fi].std() + 1e-6)
        H_p, _ = model.gcn(X_p, adj_norm)
        sens.append((H_p - H_base).abs().mean().item())

cols_f = [COLORS['primary'] if s == max(sens) else COLORS['neutral']
          for s in sens]
ax.bar(feat_names, sens, color=cols_f, edgecolor='white', alpha=0.85)
ax.set_title('Feature Sensitivity (GCN Response)')
ax.set_xticklabels(feat_names, rotation=30, ha='right', fontsize=8)
ax.set_ylabel('Mean |dH|')

ax = axes[1, 2]
sl_range = [1, 2, 4, 6, 8, 10, 12]
sl_mae   = []
model.eval()
