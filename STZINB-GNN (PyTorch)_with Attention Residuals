class AttnResGCN(nn.Module):
    """
    Multi-layer GCN with Block Attention Residuals (AttnRes).

    After all L GCN layers run sequentially, each layer's output is stored.
    A learnable pseudo-query vector ar_q[l] (one per layer, d-dimensional)
    computes dot-product attention scores against RMSNorm-ed layer outputs.
    The final node representation is a softmax-weighted sum over all L layer
    outputs — replacing the standard uniform accumulation with learned,
    input-dependent depth-wise selection.

    Key design choices (following Kimi AttnRes paper):
      - ar_q initialised to zero → uniform softmax at epoch 0 (stable start)
      - RMSNorm on keys prevents large-magnitude layers from dominating
      - Single d-dim query per layer (not multi-head) — sufficient for depth
      - ar_q trained jointly with all other parameters via backpropagation
    """
    def __init__(self, in_dim: int, gcn_dim: int, n_layers: int):
        super().__init__()
        self.n_layers = n_layers

        # GCN weight matrices W_l and bias b_l for each layer
        self.gcn_layers = nn.ModuleList([
            nn.Linear(in_dim if i == 0 else gcn_dim, gcn_dim, bias=True)
            for i in range(n_layers)
        ])

        # AttnRes pseudo-queries: one d-dim learnable vector per layer.
        # nn.Parameter ensures they are included in model.parameters()
        # and receive gradients from loss.backward().
        # Zero init → uniform softmax at initialisation (no instability).
        self.ar_q = nn.Parameter(
            torch.zeros(n_layers, gcn_dim)
        )

        # RMSNorm on keys to prevent magnitude bias in attention scores
        self.key_norm = nn.RMSNorm(gcn_dim)

        # Layer normalisation after each GCN step for training stability
        self.layer_norms = nn.ModuleList([
            nn.LayerNorm(gcn_dim) for _ in range(n_layers)
        ])

    def forward(self, X: torch.Tensor,
                A: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor]:
        """
        Parameters
        ----------
        X : [N, in_dim]  node feature matrix
        A : [N, N]       normalised adjacency matrix

        Returns
        -------
        out   : [N, gcn_dim]  AttnRes-weighted combination of layer outputs
        alpha : [n_layers]    softmax attention weights (for analysis)
        """
        layer_outputs = []
        H = X
        for i, (layer, norm) in enumerate(
                zip(self.gcn_layers, self.layer_norms)):
            # Graph convolution: H_new = ReLU(LayerNorm(A @ H @ W + b))
            H = F.relu(norm(A @ layer(H)))
            layer_outputs.append(H)

        # Stack layer outputs: V [L, N, d]
        V = torch.stack(layer_outputs, dim=0)

        # Keys: RMSNorm of mean-pooled layer outputs over nodes → [L, d]
        # Mean pooling gives a per-layer "summary" for computing attention.
        K = self.key_norm(V.mean(dim=1))

        # Attention logits: dot product of pseudo-query with each layer key
        # ar_q [L, d] · K [L, d] → logits [L]
        # After backprop, ar_q diverges from zero → non-uniform weights
        logits = torch.einsum('ld,ld->l', self.ar_q, K)
        alpha  = torch.softmax(logits, dim=0)             # [L]

        # Weighted sum of layer outputs: [N, d]
        out = torch.einsum('l,lnd->nd', alpha, V)

        return out, alpha


class TemporalAttention(nn.Module):
    """
    Single-query scaled dot-product temporal attention.

    For a sequence of GRU hidden states H [T, N, d]:
      - Query Q  : linear projection of the LAST hidden state h_T  [N, d]
      - Keys  K  : linear projection of ALL hidden states h_{1..T} [T, N, d]
      - Values V : linear projection of ALL hidden states h_{1..T} [T, N, d]
      - Scores   : Q·K^T / sqrt(d) → one scalar per (time step, node) [T, N]
      - Weights  : softmax over the TIME dimension per node            [T, N]
      - Output   : weighted sum of V over time, projected by Wo       [N, d]

    This allows the model to selectively retrieve representations from
    any past time step based on the current hidden state — capturing
    long-range temporal dependencies the GRU alone would decay.
    """
    def __init__(self, hidden_dim: int):
        super().__init__()
        self.Wq = nn.Linear(hidden_dim, hidden_dim, bias=False)
        self.Wk = nn.Linear(hidden_dim, hidden_dim, bias=False)
        self.Wv = nn.Linear(hidden_dim, hidden_dim, bias=False)
        self.Wo = nn.Linear(hidden_dim, hidden_dim, bias=False)
        self.scale = hidden_dim ** 0.5

    def forward(self, H_seq: torch.Tensor) -> tuple[torch.Tensor,
                                                     torch.Tensor]:
        """
        Parameters
        ----------
        H_seq : [T, N, d]  sequence of GRU hidden states

        Returns
        -------
        context : [N, d]   attention-weighted context vector
        weights : [T, N]   attention weights over time (for visualisation)
        """
        T, N, d = H_seq.shape

        # Query from last hidden state only
        Q = self.Wq(H_seq[-1])                          # [N, d]

        # Keys and values from full sequence
        K = self.Wk(H_seq.reshape(T * N, d)).reshape(T, N, d)  # [T, N, d]
        V = self.Wv(H_seq.reshape(T * N, d)).reshape(T, N, d)  # [T, N, d]

        # Scaled dot-product scores: one per (time, node)
        scores  = torch.einsum('nd,tnd->tn', Q, K) / self.scale  # [T, N]
        weights = torch.softmax(scores, dim=0)                    # [T, N]

        # Weighted sum over time
        context = torch.einsum('tn,tnd->nd', weights, V)
        context = self.Wo(context)                                # [N, d]

        return context, weights


class ZINBHead(nn.Module):
    """
    Zero-Inflated Negative Binomial output head.

    Three independent linear projections from the fused representation:
      pi  : zero-inflation probability ∈ (0,1)   — sigmoid activation
      mu  : NB mean                   ∈ (0, ∞)   — softplus activation
      r   : NB dispersion parameter   ∈ (0, ∞)   — softplus activation

    ZINB distribution:
      P(Y=0)  = pi + (1-pi) · (r/(r+mu))^r
      P(Y=k)  = (1-pi) · Γ(k+r)/(Γ(r)·k!) · (r/(r+mu))^r · (mu/(r+mu))^k

    Marginal mean:  E[Y] = (1 - pi) · mu
    """
    def __init__(self, input_dim: int):
        super().__init__()
        self.fc_pi  = nn.Linear(input_dim, 1)
        self.fc_mu  = nn.Linear(input_dim, 1)
        self.fc_r   = nn.Linear(input_dim, 1)

        # Initialise dispersion bias to small positive value so softplus(r)
        # starts near a reasonable dispersion (avoids degenerate NB at init)
        nn.init.constant_(self.fc_r.bias, 0.5)

    def forward(self, h: torch.Tensor) -> tuple[torch.Tensor,
                                                 torch.Tensor,
                                                 torch.Tensor]:
        """
        Parameters
        ----------
        h : [N, input_dim]  fused spatio-temporal representation

        Returns
        -------
        pi : [N]  zero-inflation probability
        mu : [N]  NB mean (expected count when in active state)
        r  : [N]  NB dispersion (larger r → less overdispersion)
        """
        pi = torch.sigmoid(self.fc_pi(h)).squeeze(-1)
        mu = F.softplus(self.fc_mu(h)).squeeze(-1) + 1e-6  # strict positive
        r  = F.softplus(self.fc_r(h)).squeeze(-1)  + 1e-4  # strict positive
        return pi, mu, r


class STZINB_GNN(nn.Module):
    """
    Spatio-Temporal Zero-Inflated Negative Binomial Graph Neural Network
    with Attention Residuals.

    Architecture (end-to-end, all parameters trained jointly):

      [Node Features: N x 8]
             |
      [AttnResGCN: 3 GCN layers + learned depth-wise AttnRes]
             |  ← ar_q trained via backprop → non-uniform depth weights
      [Spatial repr: N x gcn_dim]
             |  (repeated for each time step in [T-seq_len, T))
      [GRU: updates hidden state h across time steps]
             |
      [TemporalAttention: single-query attn over GRU sequence]
             |
      [Fusion: ReLU(concat(h_last, context) @ Wf + bf)]
             |
      [ZINBHead: 3 branches → pi, mu, r]
             |
      [ZINB NLL Loss: -E[log P(y | pi, mu, r)]]

    All 6 modules train simultaneously via a single loss.backward() call.
    """
    def __init__(self, n_nodes: int,
                 in_dim:   int = IN_DIM,
                 gcn_dim:  int = GCN_DIM,
                 hid_dim:  int = HID_DIM,
                 n_gcn:    int = N_GCN):
        super().__init__()
        self.n_nodes = n_nodes
        self.hid_dim = hid_dim

        # Spatial encoder with AttnRes
        self.gcn = AttnResGCN(in_dim, gcn_dim, n_gcn)

        # Temporal encoder
        # GRU processes the sequence of spatial representations
        self.gru = nn.GRU(
            input_size=gcn_dim,
            hidden_size=hid_dim,
            num_layers=1,
            batch_first=False,   # input: [T, N, gcn_dim]
            dropout=0.0
        )

        # Temporal attention over GRU hidden states
        self.temp_attn = TemporalAttention(hid_dim)

        # Fusion layer: combines last GRU state + temporal attention context
        self.fusion = nn.Sequential(
            nn.Linear(hid_dim * 2, hid_dim),
            nn.ReLU(),
            nn.Dropout(p=0.1),
        )

        # ZINB output head
        self.zinb = ZINBHead(hid_dim)

    def build_node_features(self, C: np.ndarray,
                             t: int) -> torch.Tensor:
        """
        Construct the 8-dimensional node feature vector for time step t.

        Features:
          0: count at t              (current observation)
          1: count at t-1            (lag 1)
          2: count at t-2            (lag 2)
          3: count at t-3            (lag 3)
          4: rolling mean over [t-4, t]
          5: rolling std  over [t-4, t]
          6: binary zero flag at t   (1 if count==0)
          7: log1p(count at t)       (stabilises scale)
        """
        N = self.n_nodes
        F_np = np.zeros((N, 8), dtype=np.float32)
        F_np[:, 0] = C[:, t]
        F_np[:, 1] = C[:, t-1] if t > 0 else 0
        F_np[:, 2] = C[:, t-2] if t > 1 else 0
        F_np[:, 3] = C[:, t-3] if t > 2 else 0
        window      = C[:, max(0, t-4):t+1]
        F_np[:, 4] = window.mean(1)
        F_np[:, 5] = window.std(1)
        F_np[:, 6] = (C[:, t] == 0).astype(np.float32)
        F_np[:, 7] = np.log1p(C[:, t])
        return torch.tensor(F_np, dtype=torch.float32, device=DEVICE)

    def encode(self, C: np.ndarray, A: torch.Tensor,
               seq_len: int) -> tuple:
        """
        Spatial + temporal encoding over the last seq_len time steps.

        For each time step t in [T-seq_len, T):
          1. Build node features X [N, 8]
          2. Run AttnResGCN to get spatial representation H_s [N, gcn_dim]
          3. Feed H_s into GRU to update hidden state

        Stack all GRU outputs into H_seq [seq_len, N, hid_dim].
        Run temporal attention over H_seq.
        Fuse last GRU hidden state with attention context.

        Returns fused [N, hid_dim], H_seq, temporal weights, AR alphas.
        """
        T        = C.shape[1]
        t_range  = range(max(0, T - seq_len), T)
        spatial_reps = []
        ar_alphas    = []

        for t in t_range:
            X        = self.build_node_features(C, t)        # [N, 8]
            H_s, al  = self.gcn(X, A)                        # [N, gcn_dim]
            spatial_reps.append(H_s)
            ar_alphas.append(al.detach().cpu().numpy())

        # Stack spatial reps: [T_seq, N, gcn_dim]
        spatial_stack = torch.stack(spatial_reps, dim=0)

        # GRU over spatial sequence
        # gru_out: [T_seq, N, hid_dim]
        # h_n:     [1,     N, hid_dim]
        gru_out, h_n = self.gru(spatial_stack)
        h_last = h_n.squeeze(0)                              # [N, hid_dim]

        # Temporal attention over GRU outputs
        context, tw = self.temp_attn(gru_out)                # [N, hid_dim]

        # Fuse last GRU state with attention context
        fused = self.fusion(
            torch.cat([h_last, context], dim=-1)             # [N, hid*2]
        )                                                     # [N, hid_dim]

        return fused, gru_out, tw, ar_alphas

    def forward(self, C: np.ndarray, A: torch.Tensor,
                seq_len: int = SEQ_LEN) -> tuple:
        """
        Full forward pass.

        Returns
        -------
        pi         : [N]  zero-inflation probabilities
        mu         : [N]  NB means
        r          : [N]  NB dispersions
        H_seq      : [T, N, hid_dim]  GRU hidden states (for visualisation)
        temp_w     : [T, N]           temporal attention weights
        ar_alphas  : list of [n_gcn] arrays  AttnRes weights per time step
        """
        fused, H_seq, temp_w, ar_alphas = self.encode(C, A, seq_len)
        pi, mu, r = self.zinb(fused)
        return pi, mu, r, H_seq, temp_w, ar_alphas

    def predict_mean(self, pi: torch.Tensor,
                      mu: torch.Tensor) -> torch.Tensor:
        """ZINB marginal mean: E[Y] = (1 - pi) * mu."""
        return (1.0 - pi) * mu

    def forecast(self, C: np.ndarray, A: torch.Tensor,
                 n_ahead: int, seq_len: int = SEQ_LEN) -> dict:
        """
        Multi-step future forecast.

        Rolls the model forward n_ahead time steps beyond the observed data.
        At each future step t:
          1. Run forward pass on the current count buffer
          2. Compute predicted mean E[Y] = (1-pi)*mu for each state
          3. Append predicted counts to the buffer as the new 'observed' step
          4. Repeat for the next step

        Note: forecast uncertainty accumulates with horizon because
        predicted counts (point estimates) replace true observations.
        The returned pi/mu/r sequences capture this growing uncertainty
        through increasing pi (model becomes less confident about activity).

        Returns a dict with:
          'pi'    : [n_ahead, N]   zero-inflation probs per future week
          'mu'    : [n_ahead, N]   NB means per future week
          'r'     : [n_ahead, N]   NB dispersions per future week
          'pred'  : [n_ahead, N]   expected counts per future week
        """
        self.eval()
        C_buf = C.copy()  # working copy — we append predicted counts to it
        results = {'pi': [], 'mu': [], 'r': [], 'pred': []}

        with torch.no_grad():
            for step in range(n_ahead):
                pi_, mu_, r_, _, _, _ = self.forward(C_buf, A, seq_len)
                pred_ = self.predict_mean(pi_, mu_).cpu().numpy()

                results['pi'].append(pi_.cpu().numpy())
                results['mu'].append(mu_.cpu().numpy())
                results['r'].append(r_.cpu().numpy())
                results['pred'].append(pred_)

                # Append predicted counts as the next observed week
                C_buf = np.concatenate(
                    [C_buf, pred_.reshape(-1, 1)], axis=1
                )

        for key in results:
            results[key] = np.stack(results[key], axis=0)  # [n_ahead, N]
        return results


