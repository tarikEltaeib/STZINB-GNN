# GBM: features = [count, lag1, lag2, lag3, mean4w] per state per time step
def make_gbm_feats(C_, t_list):
    rows = []
    for t in t_list:
        if t < 4: continue
        X_ = np.column_stack([C_[:,t], C_[:,t-1], C_[:,t-2], C_[:,t-3],
                               C_[:,max(0,t-4):t+1].mean(1)])
        rows.append(X_)
    return np.vstack(rows) if rows else np.zeros((0,5))

X_tr_gbm = make_gbm_feats(C, range(4, train_end))
y_tr_gbm = np.concatenate([C[:,t] for t in range(4, train_end)])
scaler   = StandardScaler().fit(X_tr_gbm)
gbm = GradientBoostingRegressor(n_estimators=60, random_state=42)
