      f"| Test: {T-val_end} wks | Trainable: all streams jointly")

train_losses = []
val_losses   = []
best_val     = np.inf

# Collect all trainable parameter arrays for gradient updates
def get_trainable_params(m):
    """Return list of (object, attr_name) for key trainable params."""
    params = []
    # ZINB output head
    for attr in ['Wpi','bpi','Wmu','bmu','Wr','br']:
        params.append((m.zinb_head, attr))
    # ZINB selection stage gates
    for attr in ['wz_F','bz_F','wz_B','bz_B',
                 'Wmu_F','bmu_F','Wr_F','br_F',
                 'Wmu_B','bmu_B','Wr_B','br_B']:
        params.append((m.zinb_gate, attr))
    # AttnRes pseudo-queries (both streams)
    params.append((m.analyst,    'ar_q'))
    params.append((m.strategist, 'ar_q'))
    return params

trainable = get_trainable_params(model)

for epoch in range(N_EPOCHS):
    t_batch = np.random.choice(
        range(SEQ_LEN+2, train_end), size=min(BATCH_T, train_end-SEQ_LEN-2),
        replace=False)
    epoch_loss = 0.0

    for tb in t_batch:
        pi, mu, r, _ = model.forward(C[:,:tb+1], adj_norm, SEQ_LEN)
        y    = C[:, tb].astype(np.float32)
        loss = zinb_nll(y, pi, mu, r)
        epoch_loss += loss

        # Stochastic central finite-difference gradient estimates
        eps_fd = 8e-4
        for obj, attr in trainable:
            W    = getattr(obj, attr)
            flat = W.ravel()
            g    = np.zeros_like(flat)
            n_s  = min(4, flat.size)
            idxs = np.random.choice(flat.size, n_s, replace=False)
            for ii in idxs:
                orig = flat[ii]
                flat[ii] = orig + eps_fd
                p2,m2,r2,_ = model.forward(C[:,:tb+1], adj_norm, SEQ_LEN)
                lp = zinb_nll(y, p2, m2, r2)
                flat[ii] = orig - eps_fd
                p2,m2,r2,_ = model.forward(C[:,:tb+1], adj_norm, SEQ_LEN)
                lm = zinb_nll(y, p2, m2, r2)
                flat[ii] = orig
                g[ii] = (lp - lm) / (2*eps_fd)
            setattr(obj, attr, W - LR * np.clip(g.reshape(W.shape), -0.5, 0.5))

    epoch_loss /= len(t_batch)

    # Validation
    pi_v, mu_v, r_v, _ = model.forward(C[:,:val_end], adj_norm, SEQ_LEN)
    val_loss = zinb_nll(C[:,val_end-1].astype(np.float32), pi_v, mu_v, r_v)
    train_losses.append(float(epoch_loss))
    val_losses.append(float(val_loss))

    if val_loss < best_val:
        best_val = val_loss

    if epoch % 20 == 0:
        # Show gate weights and AttnRes weights
        # Show per-layer AttnRes weights (softmax over layer axis)
        q_nF = model.analyst.ar_q.mean(1)    # [N_GCN] mean query per layer
        aF   = np.exp(q_nF - q_nF.max()); aF /= aF.sum()
        q_nB = model.strategist.ar_q.mean(1) # [N_BLOCKS]
        aB   = np.exp(q_nB - q_nB.max()); aB /= aB.sum()
        print(f"  Ep {epoch:3d} | Train:{epoch_loss:.4f} | "
              f"Val:{val_loss:.4f} | "
              f"AR_F:[{', '.join(f'{a:.3f}' for a in aF)}] | "
              f"AR_B:[{', '.join(f'{a:.3f}' for a in aB)}]")

print(f"\n  Training complete. Best Val NLL: {best_val:.4f}")

