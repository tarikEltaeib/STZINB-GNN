y_gbm    = np.expm1(gbm.predict(scaler.transform(X_te_gbm))) if len(X_te_gbm)>0 else y_mean

def metrics(yt, yp, name):
    mae  = mean_absolute_error(yt, yp)
    rmse = np.sqrt(mean_squared_error(yt, yp))
    zm   = yt==0
    zh   = (yp[zm]<0.5).mean()*100 if zm.sum()>0 else 0
    fa   = (yp[zm]>=0.5).mean()*100 if zm.sum()>0 else 0
    corr = np.corrcoef(yt,yp)[0,1] if yt.std()>0 and yp.std()>0 else 0
    return dict(Model=name,MAE=mae,RMSE=rmse,
                ZeroHit=zh,FalseAlarm=fa,Corr=corr)

results = [
    metrics(y_true, y_pred,  'STZINB-AttnRes-GNN (Ours)'),
    metrics(y_true, y_nb,    'GCN + NB (no ZI)'),
