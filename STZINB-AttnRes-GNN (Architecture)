def smap(ax, vals, title, cmap='Reds', label=''):
    ax.set_facecolor('#E8F4F8'); ax.grid(True, alpha=0.2)
    vmin=vals.min(); vmax=max(vals.max(),vmin+1e-6)
    norm=Normalize(vmin,vmax)
