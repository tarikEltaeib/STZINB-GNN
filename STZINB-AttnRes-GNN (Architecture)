def sigmoid(x):
    x = np.clip(x,-500,500)
    return np.where(x>=0, 1/(1+np.exp(-x)),
                    np.exp(x)/(1+np.exp(x)))

def softplus(x):
    return np.log1p(np.exp(-np.abs(x))) + np.maximum(x,0)

def relu(x): return np.maximum(0,x)

def rms_norm(x, eps=1e-6):
    return x / (np.sqrt((x**2).mean(-1, keepdims=True)) + eps)

def softmax_vec(x):
    e = np.exp(x - x.max())
    return e / (e.sum() + 1e-10)

def softmax_ax0(x):
    e = np.exp(x - x.max(0, keepdims=True))
    return e / (e.sum(0, keepdims=True) + 1e-10)

def zinb_nll(y, pi, mu, r):
    """Numerically stable ZINB negative log-likelihood."""
    eps = 1e-8
    pi  = np.clip(pi,  eps, 1-eps)
    mu  = np.clip(mu,  eps, 1e6)
    r   = np.clip(r,   eps, 1e4)
    log_nb0 = r*(np.log(r) - np.log(r+mu))
    log_nbk = (sp.gammaln(y+r) - sp.gammaln(r) - sp.gammaln(y+1)
               + r*(np.log(r)-np.log(r+mu))
               + y*(np.log(mu)-np.log(r+mu)))
    lp = np.where(y==0,
                  np.log(pi+(1-pi)*np.exp(log_nb0)+eps),
                  np.log(1-pi+eps)+log_nbk)
    return -np.mean(lp)

