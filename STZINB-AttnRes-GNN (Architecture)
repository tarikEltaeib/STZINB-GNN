class STZINB_AttnRes_Dual:
    """
    Dual-Stream STZINB-AttnRes-GNN with ZINB Selection Stage.

    Forward pass (per time step):
      1. Build node features X [n_states, IN_DIM]
      2. Analyst stream  : Full AttnRes GCN → H_F [n_states, GCN_DIM]
      3. Strategist stream: Block AttnRes GCN → H_B [n_states, GCN_DIM]
      4. Cross-module cache: inject Analyst detail → Strategist block sums
      5. ZINB Selection Stage: Zero gate + Count gate + ZINB fusion → H_fused
      6. GRU step (Analyst path)        → h_gru [n_states, HID_DIM]
      7. Temporal Attention (Strategist) → context [n_states, HID_DIM]
      8. Fusion: concat(h_gru, context) → ZINB head → pi, mu, r

    Training: finite-difference gradient estimates on ZINB head + selection
    stage parameters. All other parameters contribute via forward pass.
    """
    def __init__(self, n_nodes):
        self.N = n_nodes
        # Dual streams
        self.analyst    = AnalystStream(IN_DIM, GCN_DIM, N_GCN)
        self.strategist = StrategistStream(IN_DIM, GCN_DIM, N_GCN, N_BLOCKS)
        # ZINB Selection Stage
        self.zinb_gate  = ZINBSelectionStage(GCN_DIM)
        # Cross-module cache
        self.cache      = CrossModuleCache(GCN_DIM)
        # Temporal encoders
        self.gru        = GRUCell(GCN_DIM, HID_DIM)
        self.temp_attn  = TemporalAttention(HID_DIM)
        # Fusion layer
        self.Wf = np.random.randn(HID_DIM*2, HID_DIM).astype(np.float32)*0.05
        self.bf = np.zeros(HID_DIM, dtype=np.float32)
        # ZINB output head
        self.zinb_head  = ZINBHead(HID_DIM)

    def node_feats(self, C, t):
        """
        Build 10-dim node feature vector for time step t.
        [count_t, lag1, lag2, lag3, lag4,
         rolling_mean_4w, rolling_std_4w,
         zero_flag, log1p_count, neighbor_mean]
        """
        N = self.N
        F = np.zeros((N, IN_DIM), dtype=np.float32)
        F[:,0] = C[:,t]
        F[:,1] = C[:,t-1] if t>0 else 0
        F[:,2] = C[:,t-2] if t>1 else 0
        F[:,3] = C[:,t-3] if t>2 else 0
        F[:,4] = C[:,t-4] if t>3 else 0
        w      = C[:,max(0,t-4):t+1]
        F[:,5] = w.mean(1)
        F[:,6] = w.std(1)
        F[:,7] = (C[:,t]==0).astype(np.float32)
        F[:,8] = np.log1p(C[:,t])
        # Neighbor mean via one graph propagation step
        F[:,9] = (adj_norm @ C[:,t]).astype(np.float32)
        return F

    def forward(self, C, A, seq_len=SEQ_LEN):
        """Full forward pass. Returns pi, mu, r, diagnostics."""
        T = C.shape[1]
        h = np.zeros((self.N, HID_DIM), dtype=np.float32)
        H_gru_seq   = []
        H_strat_seq = []
        gate_history = []
        ar_alpha_F   = []
        ar_alpha_B   = []

        for t in range(max(0, T-seq_len), T):
            X = self.node_feats(C, t)

            # ── Analyst: Full AttnRes ──────────────────────────────────────
            H_F, alphaF, layers_F = self.analyst.forward(X, A)
            ar_alpha_F.append(alphaF)

            # ── Strategist: Block AttnRes ──────────────────────────────────
            H_B, alphaB, blocks_B = self.strategist.forward(X, A)
            ar_alpha_B.append(alphaB)

            # ── Cross-module cache: enrich block summary with Analyst detail ─
            if blocks_B:
                blocks_B[-1] = self.cache.forward(layers_F, blocks_B[-1])

            # ── ZINB Selection Stage ───────────────────────────────────────
            H_fused, gate_info = self.zinb_gate.forward(H_F, H_B)
            gate_history.append(gate_info)

            # ── GRU step (Analyst path) ────────────────────────────────────
            h = self.gru.forward(H_fused, h)
            H_gru_seq.append(h.copy())

            # ── Strategist path accumulate ─────────────────────────────────
            H_strat_seq.append(H_fused.copy())

        # ── Temporal attention over strategist sequence ────────────────────
        H_strat_stack = np.stack(H_strat_seq, 0)   # [T, N, GCN_DIM]
        # Pad to HID_DIM if needed
        if GCN_DIM != HID_DIM:
            pad = np.zeros((H_strat_stack.shape[0], self.N,
                            HID_DIM - GCN_DIM), dtype=np.float32)
            H_strat_stack = np.concatenate([H_strat_stack, pad], -1)

        context, temp_w = self.temp_attn.forward(
            np.stack(H_gru_seq, 0))    # attend over GRU sequence

        # ── Fusion ─────────────────────────────────────────────────────────
        fused = relu(np.concatenate([h, context], -1) @ self.Wf + self.bf)

        # ── ZINB output head ────────────────────────────────────────────────
        pi, mu, r = self.zinb_head.forward(fused)

        diag = {
            'ar_alpha_F':   ar_alpha_F,
            'ar_alpha_B':   ar_alpha_B,
            'gate_history': gate_history,
            'temp_w':       temp_w,
            'H_gru_seq':    np.stack(H_gru_seq, 0),
        }
        return pi, mu, r, diag

    def predict(self, pi, mu):
        """ZINB marginal mean: E[Y] = (1-pi)*mu."""
        return (1-pi)*mu


