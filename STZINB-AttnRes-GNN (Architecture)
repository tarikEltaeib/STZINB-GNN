            if adj[i,j]>0:
                ax.plot([STATE_COORDS[states[i]][1],STATE_COORDS[states[j]][1]],
                        [STATE_COORDS[states[i]][0],STATE_COORDS[states[j]][0]],
                        'gray',alpha=0.1,lw=0.6)
    for i,s in enumerate(states):
        lo,la=STATE_COORDS[s][1],STATE_COORDS[s][0]
        sz=60+160*(vals[i]-vmin)/(vmax-vmin+1e-8)
        ax.scatter(lo,la,c=[vals[i]],cmap=cmap,norm=norm,
                   s=sz,zorder=5,edgecolors='white',lw=0.5)
    sm=plt.cm.ScalarMappable(cmap=cmap,norm=norm); sm.set_array([])
    plt.colorbar(sm,ax=ax,label=label,shrink=0.7)
    ax.set_xlim(-128,-65); ax.set_ylim(23,50)
    ax.set_title(title); ax.set_xlabel('Longitude'); ax.set_ylabel('Latitude')
    for i in np.argsort(vals)[-5:]:
