class AnalystStream:
    """
    Full Attention Residuals stream.
    Every GCN layer attends over ALL prior layer outputs via learned
    pseudo-query ar_q[l] (one d-dim vector per layer, init=0).
    After training, ar_q diverges from zero → non-uniform depth weights.
    """
    def __init__(self, in_dim, gcn_dim, n_layers):
        s = 0.08
        self.gcn_W = [np.random.randn(in_dim if i==0 else gcn_dim,
                                       gcn_dim).astype(np.float32)*s
                      for i in range(n_layers)]
        self.gcn_b = [np.zeros(gcn_dim, dtype=np.float32)
                      for _ in range(n_layers)]
        # Pseudo-queries: init=0 → uniform softmax at start (stable init)
        self.ar_q  = np.zeros((n_layers, gcn_dim), dtype=np.float32)
        self.n_layers = n_layers
        self.gcn_dim  = gcn_dim

    def forward(self, X, A):
        """
        Full AttnRes forward pass.
        Returns: H [n_nodes, gcn_dim], alpha [n_layers], layer_outputs list
        """
        layer_outputs = []
        H = X
        for W, b in zip(self.gcn_W, self.gcn_b):
            H = relu(A @ H @ W + b)
            layer_outputs.append(H.copy())

        V   = np.stack(layer_outputs, 0)         # [L, N, d]
        K   = rms_norm(V.mean(1))                # [L, d]
        logits = np.einsum('ld,ld->l', self.ar_q, K)
        alpha  = softmax_vec(logits)             # [L]
        H_out  = np.einsum('l,lnd->nd', alpha, V)
        return H_out, alpha, layer_outputs


class StrategistStream:
    """
    Block Attention Residuals stream.
    Layers grouped into N_BLOCKS blocks. Within each block: standard
    additive residuals. Across blocks: learned softmax attention over
    block-level summaries only. Memory O(N*d) vs O(L*d) for Full.
    """
    def __init__(self, in_dim, gcn_dim, n_layers, n_blocks):
        s = 0.08
        self.gcn_W = [np.random.randn(in_dim if i==0 else gcn_dim,
                                       gcn_dim).astype(np.float32)*s
                      for i in range(n_layers)]
        self.gcn_b = [np.zeros(gcn_dim, dtype=np.float32)
                      for _ in range(n_layers)]
        # Block-level pseudo-queries: one per block, init=0
        self.ar_q  = np.zeros((n_blocks, gcn_dim), dtype=np.float32)
        self.n_layers = n_layers
        self.n_blocks = n_blocks
        self.gcn_dim  = gcn_dim
        self.block_sz = n_layers // n_blocks

    def forward(self, X, A):
        """
        Block AttnRes forward pass.
        Returns: H [n_nodes, gcn_dim], alpha [n_blocks], block_summaries list
        """
        block_size   = self.block_sz
        block_sums   = []
        H            = X
        layer_outputs = []

        for b_idx in range(self.n_blocks):
            start = b_idx * block_size
            end   = start + block_size
            for i in range(start, min(end, self.n_layers)):
                H = relu(A @ H @ self.gcn_W[i] + self.gcn_b[i])
                if i == start:
                    b_sum = np.zeros((H.shape[0], self.gcn_dim), dtype=np.float32)
                b_sum = b_sum + H
                layer_outputs.append(H.copy())
            block_sums.append(b_sum)

        # Cross-block attention over block summaries
        V   = np.stack(block_sums, 0)            # [n_blocks, N, d]
        K   = rms_norm(V.mean(1))                # [n_blocks, d]
        logits = np.einsum('ld,ld->l', self.ar_q, K)
        alpha  = softmax_vec(logits)             # [n_blocks]
        H_out  = np.einsum('l,lnd->nd', alpha, V)
        return H_out, alpha, block_sums


class ZINBSelectionStage:
    """
    ZINB Selection Stage — replaces simple softmax router with two gates:

    Gate 1 (Zero gate, logistic):
        z^s = sigmoid(w_z^s · h^s)
        Decides if stream s should be active at all.
        Analog of zero-inflation pi in ZINB output distribution.

    Gate 2 (Count gate, NB):
        mu^s = softplus(W_mu^s · h^s)  — expected signal strength
        r^s  = softplus(W_r^s  · h^s)  — dispersion (handles variance mismatch)
        Analog of NB mean/dispersion in ZINB output distribution.

    ZINB Fusion:
        v^s      = z^s * mu^s          — active contribution weight
        w^s      = v^s / (v^F + v^B)   — normalized blend weight
        h_fused  = w^F * h^F + w^B * h^B
    """
    def __init__(self, dim):
        s = 0.05
        # Gate 1 — Zero gate (one weight vector per stream)
        self.wz_F  = np.random.randn(dim, 1).astype(np.float32) * s
        self.bz_F  = np.zeros(1, dtype=np.float32)
        self.wz_B  = np.random.randn(dim, 1).astype(np.float32) * s
        self.bz_B  = np.zeros(1, dtype=np.float32)
        # Gate 2 — Count gate: mu and r per stream
        self.Wmu_F = np.random.randn(dim, 1).astype(np.float32) * s
        self.bmu_F = np.full(1, 0.3, dtype=np.float32)
        self.Wr_F  = np.random.randn(dim, 1).astype(np.float32) * s
        self.br_F  = np.full(1, 0.5, dtype=np.float32)
        self.Wmu_B = np.random.randn(dim, 1).astype(np.float32) * s
        self.bmu_B = np.full(1, 0.3, dtype=np.float32)
        self.Wr_B  = np.random.randn(dim, 1).astype(np.float32) * s
        self.br_B  = np.full(1, 0.5, dtype=np.float32)

    def forward(self, hF, hB):
        """
        hF, hB: [n_nodes, dim]
        Returns: h_fused [n_nodes, dim], gate_info dict
        """
        eps = 1e-6

        # ── Gate 1: Zero gate (logistic) ─────────────────────────────────
        # z ≈ 0 → stream structurally inactive (analog of pi in ZINB)
        # z ≈ 1 → stream active, proceed to count gate
        zF = sigmoid(hF @ self.wz_F + self.bz_F).squeeze(-1)  # [N]
        zB = sigmoid(hB @ self.wz_B + self.bz_B).squeeze(-1)  # [N]

        # ── Gate 2: Count gate (NB) ──────────────────────────────────────
        # mu: expected signal strength per stream
        # r:  dispersion — models reliability mismatch between streams
        muF = softplus(hF @ self.Wmu_F + self.bmu_F).squeeze(-1) + eps
        rF  = softplus(hF @ self.Wr_F  + self.br_F ).squeeze(-1) + eps
        muB = softplus(hB @ self.Wmu_B + self.bmu_B).squeeze(-1) + eps
        rB  = softplus(hB @ self.Wr_B  + self.br_B ).squeeze(-1) + eps

        # ── ZINB Fusion ──────────────────────────────────────────────────
        # Step 1: active weight = z * mu  (marginal contribution)
        vF = zF * muF                                           # [N]
        vB = zB * muB                                           # [N]
        # Step 2: normalize across streams → convex blend weights
        denom = vF + vB + eps
        wF    = vF / denom                                      # [N]
        wB    = vB / denom                                      # [N]
        # Step 3: weighted blend
        h_fused = wF[:, None] * hF + wB[:, None] * hB          # [N, dim]

        gate_info = {
            'zF': zF, 'zB': zB,
            'muF': muF, 'muB': muB,
            'rF': rF, 'rB': rB,
            'wF': wF, 'wB': wB,
        }
        return h_fused, gate_info


class CrossModuleCache:
    """
    Injects the Analyst stream's most informative layer output
    into the Strategist stream's block summary.
    h_enriched = h_block + beta * Proj(h_analyst_best)
    """
    def __init__(self, dim):
        self.Proj = np.random.randn(dim, dim).astype(np.float32) * 0.05
        self.beta = np.array([0.1], dtype=np.float32)

    def forward(self, analyst_layers, strategist_block):
        """Pick the analyst layer with max norm and inject into block summary."""
        norms  = [np.linalg.norm(L) for L in analyst_layers]
        best   = analyst_layers[int(np.argmax(norms))]
        inject = best @ self.Proj
        return strategist_block + self.beta * inject


class GRUCell:
    """Standard GRU — processes Analyst spatial representations."""
    def __init__(self, input_dim, hidden_dim):
        s = 0.08
        id_ = input_dim + hidden_dim
        self.Wr=np.random.randn(id_,hidden_dim).astype(np.float32)*s
        self.br=np.zeros(hidden_dim,dtype=np.float32)
        self.Wz=np.random.randn(id_,hidden_dim).astype(np.float32)*s
        self.bz=np.zeros(hidden_dim,dtype=np.float32)
        self.Wn=np.random.randn(id_,hidden_dim).astype(np.float32)*s
        self.bn=np.zeros(hidden_dim,dtype=np.float32)

    def forward(self, x, h):
        c  = np.concatenate([x,h],-1)
        r  = sigmoid(c@self.Wr+self.br)
        z  = sigmoid(c@self.Wz+self.bz)
        n  = np.tanh(np.concatenate([x,r*h],-1)@self.Wn+self.bn)
        return (1-z)*h + z*n


class TemporalAttention:
    """
    Single-query temporal attention — processes Strategist representations.
    Query: last hidden state. Keys/Values: full sequence.
    Retrieves long-range cyclical patterns the GRU alone would decay.
    """
    def __init__(self, dim):
        s = 0.08
        self.Wq=np.random.randn(dim,dim).astype(np.float32)*s
        self.Wk=np.random.randn(dim,dim).astype(np.float32)*s
        self.Wv=np.random.randn(dim,dim).astype(np.float32)*s
        self.Wo=np.random.randn(dim,dim).astype(np.float32)*s
        self.scale = dim**0.5

    def forward(self, H_seq):
        """H_seq: [T, N, d] → context [N, d], weights [T, N]"""
        T,N,d = H_seq.shape
        Q = H_seq[-1] @ self.Wq
        K = (H_seq.reshape(T*N,d) @ self.Wk).reshape(T,N,d)
        V = (H_seq.reshape(T*N,d) @ self.Wv).reshape(T,N,d)
        scores  = np.einsum('nd,tnd->tn', Q, K) / self.scale
        weights = softmax_ax0(scores)
        context = np.einsum('tn,tnd->nd', weights, V) @ self.Wo
        return context, weights


class ZINBHead:
    """
    ZINB output head: three independent branches.
    pi  = sigmoid(W_pi · h)   — zero-inflation probability
    mu  = softplus(W_mu · h)  — NB mean
    r   = softplus(W_r  · h)  — NB dispersion
    """
    def __init__(self, input_dim):
        s = 0.05
        self.Wpi=np.random.randn(input_dim,1).astype(np.float32)*s
        self.bpi=np.zeros(1,dtype=np.float32)
        self.Wmu=np.random.randn(input_dim,1).astype(np.float32)*s
        self.bmu=np.zeros(1,dtype=np.float32)
        self.Wr =np.random.randn(input_dim,1).astype(np.float32)*s
        self.br =np.full(1,0.5,dtype=np.float32)

    def forward(self, h):
        pi = sigmoid(h@self.Wpi+self.bpi).squeeze(-1)
        mu = softplus(h@self.Wmu+self.bmu).squeeze(-1)+1e-6
        r  = softplus(h@self.Wr +self.br ).squeeze(-1)+1e-4
        return pi, mu, r


